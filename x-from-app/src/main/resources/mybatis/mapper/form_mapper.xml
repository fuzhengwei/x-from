<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.xiaofuge.x.infrastructure.dao.IFormDao">

    <resultMap id="FormResultMap" type="cn.xiaofuge.x.infrastructure.dao.po.FormPO">
        <id column="id" property="id"/>
        <result column="form_code" property="formCode"/>
        <result column="form_name" property="formName"/>
        <result column="form_desc" property="formDesc"/>
        <result column="form_config" property="formConfig"/>
        <result column="status" property="status"/>
        <result column="creator" property="creator"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <resultMap id="FormSubmissionResultMap" type="cn.xiaofuge.x.infrastructure.dao.po.FormSubmissionPO">
        <id column="id" property="id"/>
        <result column="form_id" property="formId"/>
        <result column="form_code" property="formCode"/>
        <result column="submission_data" property="submissionData"/>
        <result column="submitter" property="submitter"/>
        <result column="submitter_ip" property="submitterIp"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insertForm" parameterType="cn.xiaofuge.x.infrastructure.dao.po.FormPO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `form` (`form_code`, `form_name`, `form_desc`, `form_config`, `status`, `creator`)
        VALUES (#{formCode}, #{formName}, #{formDesc}, #{formConfig}, #{status}, #{creator})
    </insert>

    <update id="updateForm" parameterType="cn.xiaofuge.x.infrastructure.dao.po.FormPO">
        UPDATE `form`
        <set>
            <if test="formName != null">`form_name` = #{formName},</if>
            <if test="formDesc != null">`form_desc` = #{formDesc},</if>
            <if test="formConfig != null">`form_config` = #{formConfig},</if>
            <if test="status != null">`status` = #{status},</if>
        </set>
        WHERE `id` = #{id}
    </update>

    <select id="getFormById" resultMap="FormResultMap">
        SELECT * FROM `form` WHERE `id` = #{id}
    </select>

    <select id="getFormByCode" resultMap="FormResultMap">
        SELECT * FROM `form` WHERE `form_code` = #{formCode}
    </select>

    <select id="getFormList" resultMap="FormResultMap">
        SELECT * FROM `form` ORDER BY `create_time` DESC
    </select>

    <insert id="insertFormSubmission" parameterType="cn.xiaofuge.x.infrastructure.dao.po.FormSubmissionPO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `form_submission` (`form_id`, `form_code`, `submission_data`, `submitter`, `submitter_ip`)
        VALUES (#{formId}, #{formCode}, #{submissionData}, #{submitter}, #{submitterIp})
    </insert>

    <select id="getFormSubmissions" resultMap="FormSubmissionResultMap">
        SELECT * FROM `form_submission` WHERE `form_id` = #{formId} ORDER BY `create_time` DESC
    </select>

</mapper>
